# Ollama (default — local & fast)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/mradermacher/Qwen3-8B-64k-Context-2X-Josiefied-Uncensored-i1-GGUF:Q5_K_M

