# Ollama (default — local & fast)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=dolphin-mistral:7b 

# Optional: OpenAI-compatible API instead of Ollama
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Speech-to-text (tiny=fastest, base=balanced, small=better accuracy)
WHISPER_MODEL=base
WHISPER_DEVICE=auto

# Fish Audio TTS
FISH_API_KEY=your_fish_api_key_here
FISH_MODEL=s2.1-pro-free
FISH_REFERENCE_ID=8fdb1e2c75e6474d9e8f9490670461dc

# Persona name shown in the UI
COMPANION_NAME=Nikki
